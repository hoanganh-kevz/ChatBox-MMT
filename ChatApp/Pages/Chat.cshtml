@page
@model ChatModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChatBox Messenger</title>
    <meta name="description" content="ChatBox - Ứng dụng nhắn tin realtime">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0b0d13;
            --bg-secondary: #111827;
            --bg-sidebar: #0f1119;
            --bg-card: #1a1d2e;
            --bg-card-hover: #252840;
            --bg-input: #1e2235;
            --accent: #6366f1;
            --accent-light: #818cf8;
            --accent-dark: #4f46e5;
            --accent-gradient: linear-gradient(135deg, #6366f1, #8b5cf6);
            --accent-glow: rgba(99, 102, 241, 0.3);
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --online-green: #22c55e;
            --border: rgba(255,255,255,0.06);
            --border-light: rgba(255,255,255,0.12);
            --glass: rgba(255,255,255,0.03);
            --shadow: 0 8px 32px rgba(0,0,0,0.4);
            --msg-own: linear-gradient(135deg, #6366f1, #7c3aed);
            --msg-other: #1e2235;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-primary);
            height: 100vh;
            overflow: hidden;
            color: var(--text-primary);
        }

        /* ====== LOGIN SCREEN ====== */
        .login-overlay {
            position: fixed;
            inset: 0;
            background: var(--bg-primary);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            overflow: hidden;
        }

        .login-bg-orbs {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .login-bg-orbs .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.4;
            animation: orbFloat 12s ease-in-out infinite;
        }

        .login-bg-orbs .orb:nth-child(1) {
            width: 400px; height: 400px;
            background: #6366f1;
            top: -100px; left: -100px;
            animation-delay: 0s;
        }

        .login-bg-orbs .orb:nth-child(2) {
            width: 350px; height: 350px;
            background: #8b5cf6;
            bottom: -80px; right: -80px;
            animation-delay: -4s;
        }

        .login-bg-orbs .orb:nth-child(3) {
            width: 250px; height: 250px;
            background: #06b6d4;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: -8s;
        }

        @@keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -30px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.95); }
        }

        .login-card {
            position: relative;
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border: 1px solid var(--border-light);
            padding: 48px 40px;
            border-radius: 24px;
            text-align: center;
            width: 90%;
            max-width: 420px;
            box-shadow: var(--shadow);
            animation: loginFadeIn 0.8s ease;
        }

        @@keyframes loginFadeIn {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .login-logo {
            width: 64px;
            height: 64px;
            background: var(--accent-gradient);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin: 0 auto 20px;
            box-shadow: 0 8px 24px var(--accent-glow);
        }

        .login-card h1 {
            font-size: 28px;
            font-weight: 800;
            background: var(--accent-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        .login-card .subtitle {
            color: var(--text-secondary);
            font-size: 14px;
            margin-bottom: 32px;
        }

        .login-card input {
            width: 100%;
            padding: 14px 18px;
            background: var(--bg-input);
            border: 1px solid var(--border-light);
            border-radius: 14px;
            font-size: 15px;
            color: var(--text-primary);
            font-family: inherit;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
            margin-bottom: 16px;
        }

        .login-card input::placeholder {
            color: var(--text-muted);
        }

        .login-card input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px var(--accent-glow);
        }

        .login-card .btn-login {
            width: 100%;
            padding: 14px;
            background: var(--accent-gradient);
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: transform 0.2s, box-shadow 0.2s;
            position: relative;
            overflow: hidden;
        }

        .login-card .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px var(--accent-glow);
        }

        .login-card .btn-login:active {
            transform: translateY(0);
        }

        .login-error {
            color: #f43f5e;
            font-size: 13px;
            margin-top: 12px;
            display: none;
        }

        /* ====== MAIN APP ====== */
        .app-container {
            display: flex;
            height: 100vh;
            background: var(--bg-primary);
        }

        /* ====== SIDEBAR ====== */
        .sidebar {
            width: 340px;
            min-width: 340px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .sidebar-header {
            padding: 20px 20px 12px;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .sidebar-brand h2 {
            font-size: 24px;
            font-weight: 800;
            background: var(--accent-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .btn-new-room {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            border: 1px solid var(--border-light);
            background: var(--bg-card);
            color: var(--text-primary);
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .btn-new-room:hover {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 4px 16px var(--accent-glow);
        }

        .search-box {
            width: 100%;
            padding: 10px 16px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 13px;
            color: var(--text-primary);
            font-family: inherit;
            outline: none;
            transition: border-color 0.3s;
        }

        .search-box::placeholder { color: var(--text-muted); }
        .search-box:focus { border-color: var(--accent); }

        /* Sidebar Tabs */
        .sidebar-tabs {
            display: flex;
            padding: 0 20px;
            gap: 4px;
            margin-bottom: 4px;
        }

        .sidebar-tab {
            flex: 1;
            padding: 10px;
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 10px;
            font-family: inherit;
            transition: all 0.2s;
        }

        .sidebar-tab:hover { background: var(--glass); color: var(--text-secondary); }
        .sidebar-tab.active { background: var(--bg-card); color: var(--accent-light); }

        /* Sidebar List */
        .sidebar-list {
            flex: 1;
            overflow-y: auto;
            padding: 4px 12px;
        }

        .sidebar-item {
            padding: 10px 12px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 2px;
        }

        .sidebar-item:hover { background: var(--bg-card); }
        .sidebar-item.active { background: var(--bg-card-hover); }

        .item-avatar {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 16px;
            color: white;
            flex-shrink: 0;
            position: relative;
        }

        .room-avatar {
            background: var(--bg-card-hover);
            font-size: 20px;
        }

        .online-dot {
            position: absolute;
            bottom: -1px;
            right: -1px;
            width: 12px;
            height: 12px;
            background: var(--online-green);
            border-radius: 50%;
            border: 2px solid var(--bg-sidebar);
        }

        .item-info {
            flex: 1;
            min-width: 0;
        }

        .item-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .item-desc {
            font-size: 12px;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-top: 2px;
        }

        .unread-badge {
            background: var(--accent);
            color: white;
            font-size: 11px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 10px;
            min-width: 20px;
            text-align: center;
            display: none;
        }

        /* ====== CHAT AREA ====== */
        .chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg-primary);
            min-width: 0;
        }

        .chat-header {
            padding: 14px 24px;
            background: rgba(15, 17, 25, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 14px;
            z-index: 10;
        }

        .chat-header .item-avatar { width: 38px; height: 38px; border-radius: 12px; font-size: 14px; }

        .header-info h3 {
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .header-info p {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 1px;
        }

        .header-status {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .header-status .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--online-green);
        }

        /* Welcome Screen */
        .welcome-screen {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-align: center;
            padding: 40px;
        }

        .welcome-icon {
            width: 80px;
            height: 80px;
            background: var(--bg-card);
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            margin-bottom: 20px;
        }

        .welcome-screen h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }

        .welcome-screen p {
            font-size: 14px;
            max-width: 300px;
            line-height: 1.5;
        }

        /* Messages Container */
        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px 24px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .message-group {
            display: flex;
            gap: 10px;
            max-width: 75%;
            animation: msgSlideIn 0.3s ease;
        }

        @@keyframes msgSlideIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-group.own {
            align-self: flex-end;
            flex-direction: row-reverse;
        }

        .msg-avatar {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 13px;
            color: white;
            flex-shrink: 0;
            align-self: flex-end;
        }

        .message-group.own .msg-avatar { display: none; }

        .msg-content {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .msg-sender {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            padding-left: 4px;
            margin-bottom: 2px;
        }

        .message-group.own .msg-sender { display: none; }

        .msg-bubble {
            padding: 10px 16px;
            border-radius: 18px;
            font-size: 14px;
            line-height: 1.45;
            word-wrap: break-word;
            max-width: 100%;
        }

        .message-group:not(.own) .msg-bubble {
            background: var(--msg-other);
            color: var(--text-primary);
            border-bottom-left-radius: 6px;
        }

        .message-group.own .msg-bubble {
            background: var(--msg-own);
            color: white;
            border-bottom-right-radius: 6px;
        }

        .msg-time {
            font-size: 11px;
            color: var(--text-muted);
            padding: 0 4px;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .message-group:hover .msg-time { opacity: 1; }
        .message-group.own .msg-time { text-align: right; }

        /* System Messages */
        .system-msg {
            text-align: center;
            font-size: 12px;
            color: var(--text-muted);
            padding: 8px 0;
            animation: msgSlideIn 0.3s ease;
        }

        /* Input Area */
        .input-area {
            padding: 12px 24px 20px;
            display: flex;
            gap: 10px;
            align-items: center;
            border-top: 1px solid var(--border);
            background: var(--bg-primary);
        }

        .input-wrapper {
            flex: 1;
            position: relative;
        }

        .input-wrapper input {
            width: 100%;
            padding: 12px 18px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 16px;
            font-size: 14px;
            color: var(--text-primary);
            font-family: inherit;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .input-wrapper input::placeholder { color: var(--text-muted); }

        .input-wrapper input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        .btn-send {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            border: none;
            background: var(--accent-gradient);
            color: white;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s, box-shadow 0.2s;
            flex-shrink: 0;
        }

        .btn-send:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px var(--accent-glow);
        }

        .btn-send:active { transform: translateY(0); }

        /* ====== MODAL ====== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 500;
        }

        .modal-overlay.active { display: flex; }

        .modal-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: 20px;
            padding: 32px;
            width: 90%;
            max-width: 400px;
            box-shadow: var(--shadow);
            animation: loginFadeIn 0.3s ease;
        }

        .modal-card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .modal-card input {
            width: 100%;
            padding: 12px 16px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            color: var(--text-primary);
            font-family: inherit;
            outline: none;
            margin-bottom: 12px;
            transition: border-color 0.3s;
        }

        .modal-card input::placeholder { color: var(--text-muted); }
        .modal-card input:focus { border-color: var(--accent); }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 8px;
        }

        .modal-actions button {
            flex: 1;
            padding: 10px;
            border-radius: 12px;
            border: none;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.2s;
        }

        .btn-cancel {
            background: var(--bg-card);
            color: var(--text-secondary);
            border: 1px solid var(--border) !important;
        }

        .btn-cancel:hover { background: var(--bg-card-hover); }

        .btn-create {
            background: var(--accent-gradient);
            color: white;
        }

        .btn-create:hover {
            box-shadow: 0 4px 16px var(--accent-glow);
        }

        /* ====== CONNECTION STATUS ====== */
        .connection-status {
            position: fixed;
            top: 12px;
            right: 12px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            z-index: 100;
            display: none;
            animation: loginFadeIn 0.3s ease;
        }

        .connection-status.connecting {
            display: block;
            background: rgba(234, 179, 8, 0.15);
            color: #eab308;
            border: 1px solid rgba(234, 179, 8, 0.3);
        }

        .connection-status.error {
            display: block;
            background: rgba(244, 63, 94, 0.15);
            color: #f43f5e;
            border: 1px solid rgba(244, 63, 94, 0.3);
        }

        /* ====== EMPTY ====== */
        .empty-chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-align: center;
        }

        .empty-chat .icon {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

        .empty-chat p { font-size: 14px; }

        /* ====== SCROLLBAR ====== */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--bg-card-hover); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

        /* ====== TYPING INDICATOR ====== */
        .typing-indicator {
            display: none;
            padding: 0 24px 8px;
            font-size: 12px;
            color: var(--text-muted);
            align-items: center;
            gap: 6px;
        }

        .typing-dots {
            display: flex;
            gap: 3px;
        }

        .typing-dots span {
            width: 5px;
            height: 5px;
            background: var(--text-muted);
            border-radius: 50%;
            animation: typingBounce 1.4s infinite ease-in-out;
        }

        .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
        .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

        @@keyframes typingBounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-6px); }
        }

        /* ====== User Profile Footer ====== */
        .sidebar-footer {
            padding: 12px 16px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-footer .item-avatar {
            width: 36px;
            height: 36px;
            font-size: 14px;
        }

        .sidebar-footer .user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .sidebar-footer .user-status {
            font-size: 11px;
            color: var(--online-green);
        }
    </style>
</head>
<body>
    <!-- Login Screen -->
    <div id="loginOverlay" class="login-overlay">
        <div class="login-bg-orbs">
            <div class="orb"></div>
            <div class="orb"></div>
            <div class="orb"></div>
        </div>
        <div class="login-card">
            <div class="login-logo">💬</div>
            <h1>ChatBox</h1>
            <p class="subtitle">Kết nối và trò chuyện theo thời gian thực</p>
            <input type="text" id="usernameInput" placeholder="Nhập tên hiển thị của bạn..." autocomplete="off" />
            <button class="btn-login" id="btnLogin" onclick="loginChat()">Bắt đầu trò chuyện</button>
            <div class="login-error" id="loginError"></div>
        </div>
    </div>

    <!-- Connection Status -->
    <div class="connection-status" id="connectionStatus"></div>

    <!-- Main Chat App -->
    <div class="app-container" id="chatApp" style="display:none;">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="sidebar-brand">
                    <h2>ChatBox</h2>
                    <button class="btn-new-room" id="btnNewRoom" onclick="showCreateRoomModal()" title="Tạo phòng mới">+</button>
                </div>
                <input type="text" class="search-box" id="searchInput" placeholder="Tìm kiếm cuộc trò chuyện..." oninput="filterSidebar()" autocomplete="off" />
            </div>

            <div class="sidebar-tabs">
                <button class="sidebar-tab active" id="tabRooms" onclick="switchTab('rooms')">💬 Phòng chat</button>
                <button class="sidebar-tab" id="tabUsers" onclick="switchTab('users')">👥 Trực tuyến</button>
            </div>

            <div class="sidebar-list" id="sidebarList"></div>

            <div class="sidebar-footer" id="sidebarFooter"></div>
        </div>

        <!-- Chat Area -->
        <div class="chat-area" id="chatArea">
            <!-- Welcome Screen (default) -->
            <div class="welcome-screen" id="welcomeScreen">
                <div class="welcome-icon">💬</div>
                <h2>Chào mừng đến ChatBox</h2>
                <p>Chọn một cuộc trò chuyện từ danh sách bên trái hoặc bắt đầu chat với bạn bè</p>
            </div>

            <!-- Active Chat (hidden by default) -->
            <div id="activeChatView" style="display:none; flex-direction:column; flex:1;">
                <div class="chat-header" id="chatHeader"></div>
                <div class="messages-container" id="messagesList"></div>
                <div class="typing-indicator" id="typingIndicator">
                    <div class="typing-dots"><span></span><span></span><span></span></div>
                    <span>đang nhập...</span>
                </div>
                <div class="input-area">
                    <div class="input-wrapper">
                        <input type="text" id="messageInput" placeholder="Nhập tin nhắn..." autocomplete="off" />
                    </div>
                    <button class="btn-send" id="btnSend" onclick="sendMessage()">➤</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Room Modal -->
    <div class="modal-overlay" id="createRoomModal">
        <div class="modal-card">
            <h3>✨ Tạo phòng chat mới</h3>
            <input type="text" id="roomNameInput" placeholder="Tên phòng chat" autocomplete="off" />
            <input type="text" id="roomDescInput" placeholder="Mô tả (tuỳ chọn)" autocomplete="off" />
            <div class="modal-actions">
                <button class="btn-cancel" onclick="hideCreateRoomModal()">Huỷ</button>
                <button class="btn-create" onclick="createRoom()">Tạo phòng</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // ====== STATE ======
        let currentUser = null;
        let currentUserColor = '#6366f1';
        let currentChatType = null; // 'room' | 'private'
        let currentChatId = null; // roomId or username
        let activeTab = 'rooms';
        let rooms = [];
        let onlineUsers = [];
        let isConnected = false;
        let unreadCounts = {};

        // ====== SIGNALR CONNECTION ======
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect([0, 1000, 5000, 10000])
            .build();

        // ====== EVENT HANDLERS ======
        connection.on("UserJoined", (username) => {
            if (currentChatType === 'room' && currentChatId) {
                addSystemMessage(`${username} đã tham gia`);
            }
        });

        connection.on("UserDisconnected", (username) => {
            if (currentChatType === 'room' && currentChatId) {
                addSystemMessage(`${username} đã rời đi`);
            }
        });

        connection.on("OnlineUsersUpdated", (users) => {
            onlineUsers = users;
            if (activeTab === 'users') renderSidebar();
        });

        connection.on("ReceiveMessage", (msg) => {
            if (currentChatType === 'room' && currentChatId === msg.chatRoomId) {
                // We're in the right room - but this is handled below
            }
            // Always render if it's for the current room
            if (currentChatType === 'room') {
                appendMessage(msg);
            }
        });

        connection.on("ReceivePrivateMessage", (msg) => {
            if (currentChatType === 'private') {
                const isFromPartner = msg.sender === currentChatId;
                const isFromMe = msg.sender === currentUser;
                if (isFromPartner || isFromMe) {
                    appendMessage(msg);
                    return;
                }
            }
            // Show unread indicator
            if (msg.sender !== currentUser) {
                unreadCounts[msg.sender] = (unreadCounts[msg.sender] || 0) + 1;
                if (activeTab === 'users') renderSidebar();
            }
        });

        connection.on("RoomCreated", (room) => {
            rooms.push(room);
            if (activeTab === 'rooms') renderSidebar();
        });

        connection.onreconnecting(() => {
            showConnectionStatus('connecting', 'Đang kết nối lại...');
        });

        connection.onreconnected(async () => {
            isConnected = true;
            hideConnectionStatus();
            if (currentUser) {
                await connection.invoke("JoinChat", currentUser);
            }
        });

        connection.onclose(() => {
            isConnected = false;
            showConnectionStatus('error', 'Mất kết nối');
        });

        // ====== CONNECTION ======
        async function startConnection() {
            try {
                showConnectionStatus('connecting', 'Đang kết nối...');
                await connection.start();
                isConnected = true;
                hideConnectionStatus();
            } catch (err) {
                console.error("Connection error:", err);
                isConnected = false;
                showConnectionStatus('error', 'Không thể kết nối');
                setTimeout(startConnection, 3000);
            }
        }

        function showConnectionStatus(type, text) {
            const el = document.getElementById('connectionStatus');
            el.className = 'connection-status ' + type;
            el.textContent = text;
        }

        function hideConnectionStatus() {
            document.getElementById('connectionStatus').className = 'connection-status';
        }

        // ====== LOGIN ======
        async function loginChat() {
            const username = document.getElementById("usernameInput").value.trim();
            const errorEl = document.getElementById("loginError");

            if (!username) {
                errorEl.textContent = "Vui lòng nhập tên hiển thị!";
                errorEl.style.display = "block";
                return;
            }

            if (username.length < 2) {
                errorEl.textContent = "Tên phải có ít nhất 2 ký tự!";
                errorEl.style.display = "block";
                return;
            }

            if (!isConnected) {
                errorEl.textContent = "Đang kết nối... Vui lòng đợi!";
                errorEl.style.display = "block";
                return;
            }

            try {
                errorEl.style.display = "none";
                document.getElementById("btnLogin").textContent = "Đang tham gia...";

                await connection.invoke("JoinChat", username);
                currentUser = username;

                // Load rooms
                rooms = await connection.invoke("GetRooms");

                // Get user avatar color
                const userObj = onlineUsers.find(u => u.username === username);
                if (userObj) currentUserColor = userObj.avatarColor;

                // Show app
                document.getElementById("loginOverlay").style.display = "none";
                document.getElementById("chatApp").style.display = "flex";

                renderSidebarFooter();
                renderSidebar();

                // Auto-open General room
                openRoom(rooms[0].id, rooms[0].name, rooms[0].description);

            } catch (err) {
                console.error("Login error:", err);
                errorEl.textContent = err.message || "Lỗi kết nối!";
                errorEl.style.display = "block";
                document.getElementById("btnLogin").textContent = "Bắt đầu trò chuyện";
            }
        }

        // ====== SIDEBAR ======
        function switchTab(tab) {
            activeTab = tab;
            document.getElementById('tabRooms').classList.toggle('active', tab === 'rooms');
            document.getElementById('tabUsers').classList.toggle('active', tab === 'users');
            renderSidebar();
        }

        function renderSidebar() {
            const list = document.getElementById('sidebarList');
            const searchTerm = (document.getElementById('searchInput').value || '').toLowerCase();

            if (activeTab === 'rooms') {
                const filtered = rooms.filter(r => !searchTerm || r.name.toLowerCase().includes(searchTerm));
                list.innerHTML = filtered.map(room => {
                    const isActive = currentChatType === 'room' && currentChatId === room.id;
                    const icon = room.isDefault ? '💬' : '🔵';
                    return `
                        <div class="sidebar-item ${isActive ? 'active' : ''}" onclick="openRoom(${room.id}, '${escapeAttr(room.name)}', '${escapeAttr(room.description || '')}')">
                            <div class="item-avatar room-avatar">${icon}</div>
                            <div class="item-info">
                                <div class="item-name">${escapeHtml(room.name)}</div>
                                <div class="item-desc">${escapeHtml(room.description || 'Phòng chat')}</div>
                            </div>
                        </div>
                    `;
                }).join('');
            } else {
                const filtered = onlineUsers.filter(u =>
                    u.username !== currentUser &&
                    (!searchTerm || u.username.toLowerCase().includes(searchTerm))
                );

                if (filtered.length === 0) {
                    list.innerHTML = `<div class="empty-chat" style="padding:40px 0"><p style="font-size:13px">Chưa có ai trực tuyến</p></div>`;
                    return;
                }

                list.innerHTML = filtered.map(user => {
                    const isActive = currentChatType === 'private' && currentChatId === user.username;
                    const initial = user.username.charAt(0).toUpperCase();
                    const unread = unreadCounts[user.username] || 0;
                    return `
                        <div class="sidebar-item ${isActive ? 'active' : ''}" onclick="openPrivateChat('${escapeAttr(user.username)}', '${escapeAttr(user.avatarColor)}')">
                            <div class="item-avatar" style="background:${user.avatarColor}">
                                ${initial}
                                <div class="online-dot"></div>
                            </div>
                            <div class="item-info">
                                <div class="item-name">${escapeHtml(user.username)}</div>
                                <div class="item-desc">Đang hoạt động</div>
                            </div>
                            ${unread > 0 ? `<div class="unread-badge" style="display:block">${unread}</div>` : ''}
                        </div>
                    `;
                }).join('');
            }
        }

        function renderSidebarFooter() {
            const footer = document.getElementById('sidebarFooter');
            const initial = currentUser.charAt(0).toUpperCase();
            footer.innerHTML = `
                <div class="item-avatar" style="background:${currentUserColor}">
                    ${initial}
                </div>
                <div>
                    <div class="user-name">${escapeHtml(currentUser)}</div>
                    <div class="user-status">● Trực tuyến</div>
                </div>
            `;
        }

        function filterSidebar() {
            renderSidebar();
        }

        // ====== OPEN CHAT ======
        async function openRoom(roomId, name, description) {
            currentChatType = 'room';
            currentChatId = roomId;

            document.getElementById('welcomeScreen').style.display = 'none';
            document.getElementById('activeChatView').style.display = 'flex';

            // Render header
            const header = document.getElementById('chatHeader');
            header.innerHTML = `
                <div class="item-avatar room-avatar">💬</div>
                <div class="header-info">
                    <h3>${escapeHtml(name)}</h3>
                    <p>${escapeHtml(description || 'Phòng chat')}</p>
                </div>
            `;

            // Join SignalR group
            await connection.invoke("JoinRoom", roomId);

            // Load messages
            await loadRoomMessages(roomId);

            renderSidebar();
            document.getElementById('messageInput').focus();
        }

        async function openPrivateChat(username, avatarColor) {
            currentChatType = 'private';
            currentChatId = username;

            // Clear unread
            delete unreadCounts[username];

            document.getElementById('welcomeScreen').style.display = 'none';
            document.getElementById('activeChatView').style.display = 'flex';

            const initial = username.charAt(0).toUpperCase();
            const header = document.getElementById('chatHeader');
            header.innerHTML = `
                <div class="item-avatar" style="background:${avatarColor}">
                    ${initial}
                    <div class="online-dot"></div>
                </div>
                <div class="header-info">
                    <h3>${escapeHtml(username)}</h3>
                    <div class="header-status"><div class="dot"></div><span style="font-size:12px;color:var(--online-green)">Đang hoạt động</span></div>
                </div>
            `;

            // Load messages
            await loadPrivateMessages(username);

            renderSidebar();
            document.getElementById('messageInput').focus();
        }

        // ====== LOAD MESSAGES ======
        async function loadRoomMessages(roomId) {
            const container = document.getElementById('messagesList');
            container.innerHTML = '';

            try {
                const messages = await connection.invoke("GetRoomMessages", roomId);
                if (!messages || messages.length === 0) {
                    container.innerHTML = `<div class="empty-chat"><div class="icon">💬</div><p>Chưa có tin nhắn. Hãy bắt đầu cuộc trò chuyện!</p></div>`;
                    return;
                }
                messages.forEach(msg => appendMessage(msg, false));
                scrollToBottom();
            } catch (err) {
                console.error("Load messages error:", err);
                container.innerHTML = `<div class="empty-chat"><p>Không thể tải tin nhắn</p></div>`;
            }
        }

        async function loadPrivateMessages(username) {
            const container = document.getElementById('messagesList');
            container.innerHTML = '';

            try {
                const messages = await connection.invoke("GetPrivateMessages", username);
                if (!messages || messages.length === 0) {
                    container.innerHTML = `<div class="empty-chat"><div class="icon">🔒</div><p>Bắt đầu cuộc trò chuyện riêng tư với ${escapeHtml(username)}</p></div>`;
                    return;
                }
                messages.forEach(msg => appendMessage(msg, false));
                scrollToBottom();
            } catch (err) {
                console.error("Load private messages error:", err);
                container.innerHTML = `<div class="empty-chat"><p>Không thể tải tin nhắn</p></div>`;
            }
        }

        // ====== APPEND MESSAGE ======
        function appendMessage(msg, animate = true) {
            const container = document.getElementById('messagesList');
            // Remove empty state
            const empty = container.querySelector('.empty-chat');
            if (empty) container.innerHTML = '';

            const isOwn = msg.sender === currentUser;
            const initial = msg.sender ? msg.sender.charAt(0).toUpperCase() : '?';
            const color = msg.avatarColor || '#6366f1';

            const div = document.createElement('div');
            div.className = `message-group ${isOwn ? 'own' : ''}`;
            if (!animate) div.style.animation = 'none';

            div.innerHTML = `
                <div class="msg-avatar" style="background:${color}">${initial}</div>
                <div class="msg-content">
                    <div class="msg-sender">${escapeHtml(msg.sender || 'Unknown')}</div>
                    <div class="msg-bubble">${escapeHtml(msg.content || '')}</div>
                    <div class="msg-time">${msg.time || ''}</div>
                </div>
            `;

            container.appendChild(div);
            scrollToBottom();
        }

        function addSystemMessage(text) {
            const container = document.getElementById('messagesList');
            if (!container) return;
            const empty = container.querySelector('.empty-chat');
            if (empty) container.innerHTML = '';

            const div = document.createElement('div');
            div.className = 'system-msg';
            div.textContent = text;
            container.appendChild(div);
            scrollToBottom();
        }

        function scrollToBottom() {
            const container = document.getElementById('messagesList');
            if (container) {
                setTimeout(() => { container.scrollTop = container.scrollHeight; }, 50);
            }
        }

        // ====== SEND MESSAGE ======
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;

            try {
                if (currentChatType === 'room') {
                    connection.invoke("SendMessage", message, currentChatId)
                        .catch(err => console.error("Send error:", err));
                } else if (currentChatType === 'private') {
                    connection.invoke("SendPrivateMessage", currentChatId, message)
                        .catch(err => console.error("Send private error:", err));
                }
                input.value = '';
                input.focus();
            } catch (err) {
                console.error("Send message error:", err);
            }
        }

        // ====== CREATE ROOM ======
        function showCreateRoomModal() {
            document.getElementById('createRoomModal').classList.add('active');
            document.getElementById('roomNameInput').focus();
        }

        function hideCreateRoomModal() {
            document.getElementById('createRoomModal').classList.remove('active');
            document.getElementById('roomNameInput').value = '';
            document.getElementById('roomDescInput').value = '';
        }

        async function createRoom() {
            const name = document.getElementById('roomNameInput').value.trim();
            const desc = document.getElementById('roomDescInput').value.trim();

            if (!name) {
                document.getElementById('roomNameInput').focus();
                return;
            }

            try {
                const room = await connection.invoke("CreateRoom", name, desc || 'Phòng chat tuỳ chỉnh');
                hideCreateRoomModal();
                if (room) {
                    openRoom(room.id, room.name, room.description);
                }
            } catch (err) {
                console.error("Create room error:", err);
            }
        }

        // ====== HELPERS ======
        function escapeHtml(text) {
            if (!text) return '';
            const map = { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        function escapeAttr(text) {
            if (!text) return '';
            return text.replace(/'/g, "\\'").replace(/"/g, '\\"');
        }

        // ====== KEYBOARD EVENTS ======
        document.getElementById("messageInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                sendMessage();
            }
        });

        document.getElementById("usernameInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                loginChat();
            }
        });

        document.getElementById("roomNameInput").addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                createRoom();
            }
        });

        // Close modal on overlay click
        document.getElementById("createRoomModal").addEventListener("click", (e) => {
            if (e.target === document.getElementById("createRoomModal")) {
                hideCreateRoomModal();
            }
        });

        // ====== INIT ======
        startConnection();
    </script>
</body>
</html>
